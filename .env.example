# Auditslip example environment file
# Copy to /etc/auditslip/auditslip.env and fill real secrets there.
# Do not commit the real /etc/auditslip/auditslip.env file.

# --- Telegram bot(s) ---
# Single-bot fallback:
BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
BOT_DISPLAY_NAME=Auditslip

# Multi-company / multi-bot mode. Tokens are read from env var names below.
# Format: bot_key:TOKEN_ENV_NAME:company_name
BOT_TOKEN_1=
BOT_TOKEN_2=
BOT_TOKEN_3=
BOT_TOKEN_4=
BOT_TOKEN_5=
AUDITSLIP_TELEGRAM_BOTS=bot1:BOT_TOKEN_1:บริษัท 1,bot2:BOT_TOKEN_2:บริษัท 2,bot3:BOT_TOKEN_3:บริษัท 3,bot4:BOT_TOKEN_4:บริษัท 4,bot5:BOT_TOKEN_5:บริษัท 5

# --- Paths ---
AUDITSLIP_HOME=/root/projects/auditslip
AUDITSLIP_DATA_DIR=/root/projects/auditslip/data
AUDITSLIP_EXPORT_DIR=/root/projects/auditslip/exports
AUDITSLIP_BACKEND_IMPORT_DIR=/root/projects/auditslip/imports/backend
AUDITSLIP_DB=/root/projects/auditslip/data/auditslip.db

# --- OCR providers ---
OCR_PROVIDERS=gemini,openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite
GEMINI_THINKING_BUDGET=0
GEMINI_THINKING_FALLBACK_ENABLED=1
GEMINI_FALLBACK_THINKING_BUDGET=-1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OCR_RETRY_ATTEMPTS=3
OCR_RETRY_BASE_DELAY=2

# --- Queue / polling ---
AUDITSLIP_POLL_TIMEOUT=30
AUDITSLIP_MAX_SLIPS_PER_POLL=100
AUDITSLIP_OCR_WORKERS=4
AUDITSLIP_OCR_JOB_MAX_ATTEMPTS=3
AUDITSLIP_OCR_JOB_STALE_MS=600000
AUDITSLIP_OCR_WORKER_IDLE_SLEEP=0.5
AUDITSLIP_UNCLEAR_MIN_CONFIDENCE=0.65

# Telegram group reply noise controls.
# Production groups often keep queue replies off; result replies depend on operator preference.
AUDITSLIP_REPLY_ON_QUEUE=0
AUDITSLIP_REPLY_ON_RESULT=1

# --- Dashboard ---
AUDITSLIP_DASHBOARD_HOST=0.0.0.0
AUDITSLIP_DASHBOARD_PORT=8095
AUDITSLIP_DASHBOARD_TOKEN=CHANGE_ME
AUDITSLIP_DASHBOARD_OWNER_USER=owner
AUDITSLIP_DASHBOARD_OWNER_PASSWORD=CHANGE_ME
AUDITSLIP_SIMPLE_APPROVAL=1
AUDITSLIP_ALERT_ON_MUTATION=1

# Optional explicit group flow mapping. Prefer this when Telegram group names are generic.
# Format examples: bot1|CHAT_ID=deposit,bot1|CHAT_ID2=withdraw
AUDITSLIP_FLOW_MAP=

# --- Watchdog / alerts / backups ---
AUDITSLIP_ADMIN_IDS=
AUDITSLIP_WATCHDOG_ALERT_CHAT_ID=
AUDITSLIP_WATCHDOG_AUTO_RESTART=1
AUDITSLIP_WATCHDOG_STALE_MINUTES=15
AUDITSLIP_WATCHDOG_FAILED_THRESHOLD=1
AUDITSLIP_WATCHDOG_ALERT_THROTTLE_SEC=1800
AUDITSLIP_BACKUP_DIR=/root/projects/auditslip/backups/db
AUDITSLIP_BACKUP_RETENTION_DAYS=14

# --- Optional external dashboards ---
AUDITSLIP_TWALLET_DASHBOARD_URL=
AUDITSLIP_TWALLET_TIMEOUT=2.5
AUDITSLIP_TWALLET_CACHE_TTL=20
